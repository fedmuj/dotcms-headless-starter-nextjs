# dotCMS connection (all server-only — never prefix with NEXT_PUBLIC_).
# See README.md section 2 for where to find each value.

# Base URL of the dotCMS instance.
DOTCMS_HOST=https://your-instance.dotcms.cloud

# API token from a user with edit permissions on the site.
# dotCMS -> Settings -> Users -> (user) -> API Access Tokens
DOTCMS_AUTH_TOKEN=

# Identifier of the site to serve content from.
# dotCMS -> Settings -> Sites -> (your site)
DOTCMS_SITE_ID=

# Honor the UVE editor's ?mode=... params (preview/editing only).
# Leave unset or false in production so only LIVE content is served.
ENABLE_UVE_MODE=true
